# Database
DATABASE_URL="postgresql://user:password@localhost:5432/pinenova"

# JWT
JWT_SECRET="your-jwt-secret-at-least-32-chars-long"
JWT_REFRESH_SECRET="your-refresh-secret-at-least-32-chars-long"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# AWS S3
S3_ACCESS_KEY_ID="your-access-key-id"
S3_SECRET_KEY="your-secret-key"
S3_BUCKET_NAME="pinenova-images"
S3_REGION="us-east-1"

# Email
EMAIL_FROM="noreply@pinenova.com"
SENDGRID_API_KEY="SG.your-sendgrid-api-key"

# OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
APPLE_CLIENT_ID="your-apple-client-id"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
